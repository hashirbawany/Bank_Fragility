# Copy this file to .env and fill in your values
# cp .env.sample .env

# ── Report date ────────────────────────────────────────────────────────────────
# The Call Report quarter-end date to analyse. Format: MM/DD/YYYY
# Example values: 12/31/2024  |  03/31/2025  |  06/30/2025
REPORT_DATE_SLASH=12/31/2024

# ── RMBS haircut multiplier ────────────────────────────────────────────────────
# Scales the unrealised loss on residential MBS held-to-maturity.
# 1.25 matches the assumption in Jiang et al. (2023). Change with care.
RMBS_MULTIPLIER=1.25

# ── FRED API key ───────────────────────────────────────────────────────────────
# Free key from https://fred.stlouisfed.org/docs/api/api_key.html
# Used to pull Treasury yield curves for the yield-shock calculation.
FRED_API_KEY=your_fred_api_key_here
